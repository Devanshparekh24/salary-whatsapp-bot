# ── SQL Server Config ──────────────────────────────────
DB_SERVER=PGSERVER       # e.g. DESKTOP-ABC\SQLEXPRESS or 192.168.1.10
DB_DATABASE=SARP    # e.g. HRPayroll
DB_USER=sa          # e.g. sa
DB_PASSWORD=topface

# ── Table & Column Mapping ─────────────────────────────
DB_TABLE=dbo.Att_vw_Demo        # Your table name

# ── Schedule: day of month to send (1–28) ─────────────
SEND_DAY=1                        # e.g. 1 = 1st of every month
SEND_HOUR=9                       # 9 = 9:00 AM
SEND_MINUTE=0

# ── Company Name (shown in message) ───────────────────
COMPANY_NAME=SDC Pvt. Ltd.

# ── Delay between messages in ms (avoid spam block) ───
MESSAGE_DELAY_MS=3000             # 3 seconds between each message
